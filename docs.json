{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Clamly",
  "description": "Documentation for Clamly, the all-in-one study platform with AI quizzes, flashcards, notes, and more.",
  "colors": {
    "primary": "#f46d55",
    "light": "#fcb4a4",
    "dark": "#f46d55"
  },
  "favicon": "https://media.brand.dev/4c982d40-85e6-401d-84e8-0af20000860e.png",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "search": {
    "prompt": "Search Clamly docs..."
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Status",
          "icon": "activity",
          "href": "https://clamly.app/status"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "mailto:support@clamly.app"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Get started",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "introduction"
            ]
          },
          {
            "group": "Setup",
            "pages": [
              "getting-started/create-account",
              "getting-started/plans"
            ]
          }
        ]
      },
      {
        "tab": "Features",
        "groups": [
          {
            "group": "Study tools",
            "pages": [
              "study-tools/quizzes",
              "study-tools/flashcards",
              "study-tools/notes",
              "study-tools/focus-timer",
              "study-tools/todos",
              "study-tools/exams"
            ]
          },
          {
            "group": "AI",
            "pages": [
              "ai/clamly-ai",
              "ai/clamly-chat"
            ]
          },
          {
            "group": "Collaboration",
            "pages": [
              "collaboration/study-groups",
              "collaboration/sharing"
            ]
          }
        ]
      },
      {
        "tab": "Account",
        "groups": [
          {
            "group": "Settings",
            "pages": [
              "account/profile",
              "account/billing",
              "account/notifications",
              "account/google-calendar",
              "account/data-export"
            ]
          }
        ]
      },
      {
        "tab": "Help",
        "groups": [
          {
            "group": "Help",
            "pages": [
              "help/faq",
              "help/status"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open Clamly",
      "href": "https://clamly.app"
    }
  },
  "footer": {
    "socials": {}
  }
}
